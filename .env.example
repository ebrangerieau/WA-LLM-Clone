# ============================================================
# WA-LLM-Clone — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- OpenRouter API ---
# Obtenez votre clé sur https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# --- TinyAuth ---
# Identifiants de connexion à l'interface
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password

# --- JWT ---
# Secret pour signer les tokens JWT (générez une valeur aléatoire)
JWT_SECRET=super-secret-jwt-key-change-me

# --- URLs (pour Docker Compose) ---
# URL du backend, vue depuis le navigateur
NEXT_PUBLIC_API_URL=http://localhost:8010

# URL du frontend (CORS backend)
FRONTEND_URL=http://localhost:3010

# --- Connecteurs MCP : Google Agenda ---
# Créez un projet sur https://console.cloud.google.com/
# Activez l'API Google Calendar, créez des identifiants OAuth 2.0
# URI de redirection autorisé : http://localhost:8010/api/connectors/google_calendar/oauth/callback
GOOGLE_CLIENT_ID=votre-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8010/api/connectors/google_calendar/oauth/callback

